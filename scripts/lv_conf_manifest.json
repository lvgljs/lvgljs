{
  "lvgl_root": "deps/lvgl/src",
  "_fields": {
    "header": "LVGL header path relative to lvgl_root",
    "name": "Section label in generated lv_conf.cpp / lv_conf.ts",
    "symbols": "Export these C symbols by name (#define or extern lv_style_prop_t / uint16_t / uint32_t; no enum parsing)",
    "extern_type": "Auto-detect and export every `extern <type> NAME;` in the header (e.g. lv_style_prop_t); like enum_typedef but for extern declarations",
    "define_prefix": "Auto-detect and export every object-like `#define <prefix>...` macro in the header (function-like macros are skipped)",
    "enum_typedef": "C typedef naming the enum block to export (typedef enum {...} T, enum {...}; typedef ... T;, or enum T {...})",
    "guard": "Wrap section in #if guard in lv_conf.cpp",
    "renames": "Section-level: map C enum member to lv_conf export name (lv_conf.ts/cpp and alias value side). Example: _LV_EVENT_LAST -> LV_EVENT_LAST",
    "doc": "Optional section doc in generated lv_conf.cpp / lv_conf.ts (string or string array). Member comments are parsed from enum bodies only.",
    "relationship": "Key in scripts/style_relationship_report.json (e.g. css_extend) supplying symbols and doc",
    "alias": "Optional enum alias map in lv_types.ts: export, doc, type_name (keyof alias), exclude, source (lv_conf or header), strip_prefix, strip_suffix, to_lowercase, underscore_to_hyphen (opt-in: replace _ with - after other transforms), renames (semantic alias-map keys only - applied before strip_*; does not change lv_conf export names)",
    "function_prefix": "Auto-detect function declarations with this prefix in header order; generates lv_anim_path.cpp/.h and a numeric-index alias map (requires alias.export and export_cpp_array)",
    "export_cpp_array": "Generated const lv_anim_path_cb_t[] name (function_prefix sections only)",
    "stub": "When true, lv_conf.stub.ts resolves numeric literals from C headers (fake from 1 per section when unresolvable); when false/omitted, stub uses fake values from 1 per section"
  },
